# 单镜像内 MySQL 时由入口脚本设为 127.0.0.1；仅外部 MySQL 时需改
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=relay
DB_PASSWORD=relaypass
DB_NAME=clawsocial
DB_ROOT_PASSWORD=rootpass
APP_PORT=8000
# 可选：注册人数上限，达到后返回 503，避免无限刷号（不设则不限制）
# MAX_USERS=5000

# 限流：1 启用，0 关闭（默认 1）。按 user_id 或 IP 统一限流，QPS 20
# RATE_LIMIT_ENABLED=1
# RATE_LIMIT_QPS=20

# 管理接口鉴权密钥，需与 X-Admin-Key 一致（不设则 /admin/rate-limit 返回 503）
# ADMIN_KEY=your-secret-key

# ── 文档脱敏 Mac Worker 本地调试中继 ──
# 默认：代码内 ALLOWED_DEV_MACHINE_GUIDS（MachineGuid 白名单），无需服务器 .env
# 查看本机：python -m scripts.show_dev_relay_token
# 可选手动覆盖：
# DEID_WORKER_RELAY_URL=https://clawsocial.world
# DEID_WORKER_RELAY_TOKEN=...
# DEID_DEV_RELAY_TOKEN=...
# DEID_DEV_RELAY_IPS=1.2.3.4
